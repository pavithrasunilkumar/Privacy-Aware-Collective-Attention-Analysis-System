# =========================================================
# ClassWatch — .gitignore
# =========================================================

# ---------------------------------------------------------
# Python
# ---------------------------------------------------------
__pycache__/
*.py[cod]
*.pyd
*.pyo
.Python

# Distribution / build
build/
dist/
*.egg-info/
.eggs/

# Testing / cache
.pytest_cache/
.mypy_cache/
.cache/

# Jupyter
.ipynb_checkpoints/

# ---------------------------------------------------------
# Virtual Environments
# ---------------------------------------------------------
venv/
env/
.venv/

# ---------------------------------------------------------
# Environment Variables / Secrets
# ---------------------------------------------------------
.env
.env.*

# ---------------------------------------------------------
# IDEs / Editors
# ---------------------------------------------------------
.vscode/
.idea/

# ---------------------------------------------------------
# OS Files
# ---------------------------------------------------------
.DS_Store
Thumbs.db

# ---------------------------------------------------------
# Runtime Data / Outputs
# ---------------------------------------------------------
data/
outputs/
runs/
logs/

# Temporary files
*.tmp
*.temp
*.log

# CSV exports
*.csv

# ---------------------------------------------------------
# AI / Model Files
# ---------------------------------------------------------
# Download separately
*.pt
*.pth
*.onnx
*.engine
*.tflite

# YOLO / Ultralytics cache
datasets/
weights/

# ---------------------------------------------------------
# Media / Generated Files
# ---------------------------------------------------------
*.mp4
*.avi
*.mov
*.mkv

# Screenshots / generated images
screenshots/
captures/

# ---------------------------------------------------------
# Deployment
# ---------------------------------------------------------
*.pid
gunicorn.log

# ---------------------------------------------------------
# ArchitectIQ
# ---------------------------------------------------------
.architectiq/

# ---------------------------------------------------------
# Optional audio cache
# ---------------------------------------------------------
_sounddevice_data/

# ---------------------------------------------------------
# CUDA / Torch temporary cache
# ---------------------------------------------------------
torch_compile_debug/